{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":disableRateLimiting",
    "schedule:monthly",
    "helpers:pinGitHubActionDigestsToSemver"
  ],
  "timezone": "America/New_York",
  "labels": [
    "renovate"
  ],
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "schedule": [
      "at any time"
    ]
  },
  "postUpdateOptions": [
    "gomodTidy",
    "gomodUpdateImportPaths"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "gomod"
      ],
      "matchPackageNames": [
        "github.com/ilyalavrenov/pantograph"
      ],
      "enabled": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/\\.github/workflows/.*\\.yml$/"
      ],
      "matchStrings": [
        "(?://|#) renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?\\n[\\s\\S]*?(?:= \"|: \"|: \\S+:)(?<currentValue>[^\\s\"]+)"
      ]
    }
  ]
}
